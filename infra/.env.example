# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=n8n

# N8N_PORT=5678 — порт процесса n8n внутри Docker (не путать с nginx :80)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost/
N8N_EDITOR_BASE_URL=http://localhost/
N8N_PROXY_HOPS=1
# Локально по HTTP (Safari): иначе ошибка secure cookie
N8N_SECURE_COOKIE=false

GENERIC_TIMEZONE=Europe/Moscow
TZ=Europe/Moscow

# Порт nginx на хосте (если 80 занят — поставь 8080 и WEBHOOK_URL=http://localhost:8080/)
NGINX_PORT=80

# Queue mode (неделя 2). Оставь пустым, если n8n уже работал — ключ в volume n8n_data.
# Для нового инстанса: openssl rand -hex 32
# N8N_ENCRYPTION_KEY=

# Observability (неделя 6)
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# FastAPI gateway (неделя 7)
WEBHOOK_HMAC_SECRET=super_test_secret_123
N8N_WEBHOOK_URL=http://n8n:5678/webhook/google-sheet
IDEMPOTENCY_TTL_SECONDS=86400
# IDEMPOTENCY_KEY_PREFIX=gateway:idempotency:

# nginx rate limit для /webhook/ — в infra/nginx/nginx.conf (rate=10r/s, burst=20)

# Опционально: для алертов Grafana → Telegram (настраивается в UI, см. observability/grafana/.../README.md)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
